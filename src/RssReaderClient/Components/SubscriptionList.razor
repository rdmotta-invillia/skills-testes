@using System.Net.Http.Json
@using RssReaderApi.Models

<div class="subscription-list">
    <h3>My Subscriptions</h3>

    @if (isLoading)
    {
        <div class="loading">Loading subscriptions...</div>
    }
    else if (subscriptions.Count == 0)
    {
        <div class="empty-state">
            <p>No subscriptions yet. Add your first subscription above!</p>
        </div>
    }
    else
    {
        <div class="subscriptions">
            @foreach (var subscription in subscriptions)
            {
                <div class="subscription-item">
                    <span class="subscription-url">@subscription.Url</span>
                </div>
            }
        </div>
        <div class="subscription-count">
            Total: @subscriptions.Count subscription@(subscriptions.Count != 1 ? "s" : "")
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }
</div>

@code {
    [Inject]
    private HttpClient HttpClient { get; set; } = null!;

    [Parameter]
    public int RefreshTrigger { get; set; }

    private List<Subscription> subscriptions = new();
    private string errorMessage = string.Empty;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubscriptions();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (RefreshTrigger > 0)
        {
            await LoadSubscriptions();
        }
    }

    private async Task LoadSubscriptions()
    {
        try
        {
            errorMessage = string.Empty;
            isLoading = true;
            subscriptions = await HttpClient.GetFromJsonAsync<List<Subscription>>("/api/subscriptions") ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading subscriptions: {ex.Message}";
            subscriptions = new();
        }
        finally
        {
            isLoading = false;
        }
    }
}

<style>
.subscription-list {
    padding: 1rem;
    border: 1px solid #ddd;
    border-radius: 4px;
}

.loading {
    text-align: center;
    padding: 2rem;
    color: #666;
}

.empty-state {
    text-align: center;
    padding: 2rem;
    color: #999;
}

.subscriptions {
    list-style: none;
    padding: 0;
}

.subscription-item {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #eee;
    display: flex;
    align-items: center;
}

.subscription-item:last-child {
    border-bottom: none;
}

.subscription-url {
    word-break: break-all;
    color: #0066cc;
}

.subscription-count {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #eee;
    font-size: 0.9rem;
    color: #666;
}

.alert {
    padding: 0.75rem 1.25rem;
    margin-top: 1rem;
    border-radius: 4px;
}

.alert-danger {
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
}
</style>
