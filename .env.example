# Configurações de Ambiente - Leitor RSS
# Copie este arquivo para .env e configure conforme necessário

# ============================================================================
# INFORMAÇÕES DO PROJETO
# ============================================================================

PROJECT_NAME=RSSFeedReader
PROJECT_VERSION=1.0.0
ENVIRONMENT=development

# ============================================================================
# .NET CONFIGURATION
# ============================================================================

# Versão do .NET
DOTNET_VERSION=8.0.0

# Usar file watcher para hot reload em containers
DOTNET_USE_POLLING_FILE_WATCHER=true

# CLI Home directory
DOTNET_CLI_HOME=/workspace/.dotnet

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================

# Porta da API
API_PORT=5000
API_HTTPS_PORT=5001

# Endpoint base da API
API_BASE_URL=http://localhost:5000

# Configurações de CORS
CORS_ORIGINS=http://localhost:7000,http://localhost:7001,https://localhost:7001

# Configurações de segurança
ENABLE_HTTPS=false
ASPNETCORE_ENVIRONMENT=Development

# ============================================================================
# FRONTEND BLAZOR CONFIGURATION
# ============================================================================

# Porta do Frontend
FRONTEND_PORT=7000
FRONTEND_HTTPS_PORT=7001

# Endpoint da API do qual o frontend faz requisições
FRONTEND_API_BASE_URL=http://localhost:5000

# ============================================================================
# PYTHON CONFIGURATION
# ============================================================================

# Versão do Python
PYTHON_VERSION=3.11

# Não escrever bytecode
PYTHONDONTWRITEBYTECODE=1

# Output não buffered
PYTHONUNBUFFERED=1

# ============================================================================
# GitHub Spec Kit CONFIGURATION
# ============================================================================

# Modelo de IA a usar
SPEC_KIT_AI_MODEL=copilot

# Tipo de script (sh para Linux/macOS, ps para Windows)
SPEC_KIT_SCRIPT_TYPE=sh

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Nível de log
LOG_LEVEL=Information

# Enable detailed logging
VERBOSE_LOGGING=false

# ============================================================================
# DESENVOLVIMENTO
# ============================================================================

# Recarregar automáticamente ao salvar mudanças
WATCH_MODE=true

# ============================================================================
# DOCKER CONFIGURATION (para Dev Container)
# ============================================================================

# Usar BuildKit (builds mais rápidos)
DOCKER_BUILDKIT=1

# Compose BuildKit
COMPOSE_DOCKER_CLI_BUILD=1

# ============================================================================
# GITHUB CONFIGURATION
# ============================================================================

# Token do GitHub (opcional, para CLI autenticado)
# GITHUB_TOKEN=seu_token_aqui

# Nome do usuário do GitHub
# GITHUB_USER=seu_username_aqui
